# Core service config
APP_ENV=local
APP_VERSION=0.1.0
API_KEY=

# Database (PostgreSQL example)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload handling
UPLOAD_MODE=local
MEDIA_ROOT=./media
MEDIA_URL_PATH=/media
MEDIA_MAX_UPLOAD_SIZE=15728640

# AI pipeline
AI_ENABLE_CLASSIFIER=true
AI_CONFIDENCE_THRESHOLD=0.6
AI_COLOR_TOPK=2
AI_ONNX=false
# AI_ONNX_MODEL_PATH=

# AWS (only required when UPLOAD_MODE=s3)
AWS_REGION=
S3_BUCKET_NAME=

# Seeding
SEED_ON_START=true
SEED_LIMIT=25
SEED_KEY=local-seed-v1
