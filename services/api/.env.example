# Runtime environment
APP_ENV=local
APP_VERSION=0.1.0
API_KEY=

# Database connection
# Local Docker Postgres default:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
# Supabase direct connection example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Supabase Supavisor session pool example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# The app normalizes `postgres://` and `postgresql://` URLs to the psycopg SQLAlchemy
# driver automatically, so Supabase-provided connection strings can be pasted directly.

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload handling
UPLOAD_MODE=local
MEDIA_ROOT=./media
MEDIA_URL_PATH=/media
MEDIA_MAX_UPLOAD_SIZE=15728640

# Startup safety
# Local default: RUN_MIGRATIONS_ON_START=true, RUN_SEED_ON_START=true
# Staging/production default: both false unless explicitly enabled
RUN_MIGRATIONS_ON_START=true
RUN_SEED_ON_START=true

# AI pipeline
AI_ENABLE_CLASSIFIER=true
AI_CONFIDENCE_THRESHOLD=0.6
AI_SUBCATEGORY_CONFIDENCE_THRESHOLD=0.5
AI_COLOR_USE_MASK=true
AI_COLOR_MASK_METHOD=grabcut
AI_COLOR_MIN_FOREGROUND_PIXELS=3000
AI_COLOR_TOPK=2
AI_DEVICE=cpu
AI_ONNX=false
# AI_ONNX_MODEL_PATH=

# AWS (only required when UPLOAD_MODE=s3)
AWS_REGION=
S3_BUCKET_NAME=

# Seeding
SEED_LIMIT=25
SEED_KEY=local-seed-v1
