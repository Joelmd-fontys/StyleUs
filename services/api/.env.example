APP_ENV=local
APP_VERSION=0.1.0

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local-only auth bypass defaults.
LOCAL_AUTH_BYPASS=true
LOCAL_AUTH_USER_ID=00000000-0000-0000-0000-000000000001
LOCAL_AUTH_EMAIL=local-user@styleus.invalid

# Required in staging/production and for local live uploads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
# Legacy shared-secret projects only:
# SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SIGNED_URL_TTL_SECONDS=3600
SUPABASE_HTTP_TIMEOUT_SECONDS=15

MEDIA_ROOT=./media
MEDIA_MAX_UPLOAD_SIZE=15728640

RUN_MIGRATIONS_ON_START=true
RUN_SEED_ON_START=true

AI_ENABLE_CLASSIFIER=true
AI_DEVICE=cpu
AI_CONFIDENCE_THRESHOLD=0.6
AI_SUBCATEGORY_CONFIDENCE_THRESHOLD=0.5
AI_COLOR_USE_MASK=true
AI_COLOR_MASK_METHOD=grabcut
AI_COLOR_MIN_FOREGROUND_PIXELS=3000
AI_COLOR_TOPK=2
AI_ONNX=false
# AI_ONNX_MODEL_PATH=
AI_JOB_MAX_ATTEMPTS=3
AI_JOB_POLL_INTERVAL_SECONDS=0.5
AI_JOB_STALE_AFTER_SECONDS=300

SEED_LIMIT=25
SEED_KEY=local-seed-v1
